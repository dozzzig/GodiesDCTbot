# Neon PostgreSQL connection string
# Format: postgres://user:password@host/database?sslmode=require
DATABASE_URL=postgres://user:password@host.neon.tech/neondb?sslmode=require

# TonAPI key from https://tonconsole.com
TONAPI_KEY=your_tonapi_key_here

# Telegram bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# Your personal Telegram ID (get from @userinfobot)
ADMIN_CHAT_ID=784304118

# Parser interval in minutes (default: 30)
PARSE_INTERVAL_MIN=30
