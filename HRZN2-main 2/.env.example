# Переменные окружения для Горизонт 2 VPN Bot
# Скопируй этот файл в .env и заполни реальными значениями
# НИКОГДА не коммить .env в git!

# ─── Telegram Bot ─────────────────────────────────────────────────
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WEBHOOK_URL=https://yourdomain.com
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET=your-random-secret-string-here

# ─── Neon PostgreSQL ──────────────────────────────────────────────
# Формат: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── 3X-UI Panel ─────────────────────────────────────────────────
XUI_HOST=https://panel.yourdomain.com:2053
XUI_USERNAME=admin
XUI_PASSWORD=your_xui_password
XUI_INBOUND_ID=1

# ─── CryptoPay (@CryptoBot) ───────────────────────────────────────
CRYPTOPAY_TOKEN=your_cryptopay_token_from_cryptobot
CRYPTOPAY_TESTNET=false

# ─── Бизнес-логика ────────────────────────────────────────────────
TRIAL_HOURS=24
REFERRAL_FIRST_DAYS=10
REFERRAL_NEXT_DAYS=4

# ─── Администраторы (через запятую) ───────────────────────────────
ADMIN_IDS=123456789,987654321

# ─── Ссылки на документы ──────────────────────────────────────────
TERMS_URL=https://yourdomain.com/terms
PRIVACY_URL=https://yourdomain.com/privacy
